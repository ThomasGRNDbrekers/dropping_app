# --- 2. HULPFUNCTIES (LOGICA) ---

def haversine_distance(p1, p2):
    """Berekent afstand tussen twee (lat, lon) punten in meters."""
    R = 6371000 # Straal van de aarde in meters
    lat1, lon1 = p1
    lat2, lon2 = p2
    phi1, phi2 = radians(lat1), radians(lat2)
    dphi, dlambda = radians(lat2 - lat1), radians(lon2 - lon1)
    a = sin(dphi / 2)**2 + cos(phi1) * cos(phi2) * sin(dlambda / 2)**2
    return 2 * R * asin(sqrt(a))

def get_distance_to_line(p_current, p_start, p_finish):
    """
    Berekent de loodrechte afstand van de huidige positie tot de ideale lijn.
    Versimpelde formule voor kleine afstanden, omgezet naar meters.
    """
    y_c, x_c = p_current
    y_s, x_s = p_start
    y_f, x_f = p_finish
    
    # Loodrechte afstand berekenen in graden
    numerator = abs((y_f - y_s) * x_c - (x_f - x_s) * y_c + x_f * y_s - y_f * x_s)
    denominator = sqrt((y_f - y_s)**2 + (x_f - x_s)**2)
    
    # Omzetten naar meters (benadering: 1 graad lat = 111.32 km)
    return (numerator / denominator) * 111320

def calculate_score(afwijking_meters):
    """Bereken een score op basis van afwijking (100% is perfect)."""
    score = 100 - (afwijking_meters / 10) # -1% per 10 meter afwijking
    return max(0, int(score))

